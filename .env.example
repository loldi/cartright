# Cartright production environment.
# Copy to `.env` and fill in real values. NEVER commit the real .env - only this
# example template is tracked. On a host (Render/Fly.io), set these as secrets.

# --- Claude (Anthropic) ---
# API key for live preference parsing + alert composition (Claude Sonnet).
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram (messaging) ---
# Bot token from @BotFather (looks like "123456789:AA...").
TELEGRAM_BOT_TOKEN=123456789:AA...
# Secret token you pass as `secret_token` when registering the webhook via
# setWebhook; Telegram echoes it in the X-Telegram-Bot-Api-Secret-Token header
# and /telegram verifies it (fail-closed). Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# --- walmart.io (catalog/pricing) ---
WM_CONSUMER_ID=00000000-0000-0000-0000-000000000000
WM_KEY_VERSION=1
# PKCS#8 RSA private key whose public half is uploaded to the Walmart developer
# portal. Accepts either a PEM block (keep the literal newlines) or the raw
# base64-encoded DER the docs describe ("PKCS#8, base64-encoded").
WM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Optional Impact Radius publisher id for commission attribution.
WM_PUBLISHER_ID=

# --- Cartright ---
# The single private Telegram chat id this instance serves. Inbound updates from
# any other chat are ignored. (Message your bot, then read the chat id from the
# getUpdates response, or via @userinfobot.)
CARTRIGHT_USER_CHAT_ID=123456789
# Path to the structured order-history JSON produced by the (excluded) self-scrape.
CARTRIGHT_ORDER_HISTORY_PATH=./orders.json
# File-backed SQLite path (defaults to cartright.db).
CARTRIGHT_DB_PATH=cartright.db
# Public base URL of the review page, used to build alert links.
CARTRIGHT_REVIEW_BASE_URL=https://your-app.onrender.com/review
# Validate the X-Telegram-Bot-Api-Secret-Token on inbound /telegram requests.
# Defaults to ON (fail-closed); set to "0" only for local testing.
CARTRIGHT_VALIDATE_TELEGRAM_SECRET=1
# HMAC secret that signs review links and is verified by /review. When set,
# /review rejects any link without a valid, non-expired token (so an attacker
# can't drive walmart.io calls). Generate with: openssl rand -hex 32
# Use the SAME value here and on the host so alert links resolve.
CARTRIGHT_REVIEW_TOKEN_SECRET=
# Set to 1 to run the proactive alert loop in-process alongside the web app.
CARTRIGHT_RUN_SCHEDULER=1
# How often the alert loop runs, in seconds (default 3600).
CARTRIGHT_SCHEDULER_INTERVAL_SECONDS=3600
